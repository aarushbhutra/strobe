# MongoDB connection (required)
# Local dev: use the default below
# Railway: set MONGO_URL automatically via the MongoDB plugin
MONGO_URI=mongodb://localhost:27017
MONGO_DB=strobe

# Abuse prevention (optional — defaults shown)
MAX_FLAGS=10000
FLAG_TTL_DAYS=90

# Set to false to disable rate limiting (e.g. during tests)
RATE_LIMIT_ENABLED=true
